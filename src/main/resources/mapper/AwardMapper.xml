<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.wanjune.minilottery.mapper.AwardMapper">

    <select id="queryByActivityId" resultType="Award">
        SELECT * FROM award WHERE activity_id = #{activityId} ORDER BY sort
    </select>

</mapper>
